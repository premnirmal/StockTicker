# Environment for Xcode build-phase scripts (sourced by the "Compile Kotlin/Native
# framework" run-script phase in project.yml).
#
# Xcode runs build phases with a minimal environment that does NOT include your
# interactive shell profile (~/.zprofile, ~/.zshrc, etc.), so a JDK that works in
# Terminal may be invisible to Gradle here — it then fails with:
#     Unable to locate a Java Runtime
#
# This file provides a sensible default JAVA_HOME. It only sets JAVA_HOME when it
# is not already set, so an environment that already exports JAVA_HOME (for
# example CI via actions/setup-java) is left untouched.
#
# To point at a specific JDK on your machine WITHOUT committing the change, create
# iosApp/.xcode.env.local (it is git-ignored) with, e.g.:
#     export JAVA_HOME=/Applications/Android\ Studio.app/Contents/jbr/Contents/Home
# The run-script phase sources .xcode.env.local AFTER this file, so it wins.
if [ -z "$JAVA_HOME" ]; then
  export JAVA_HOME="$(/usr/libexec/java_home 2>/dev/null)"
fi
